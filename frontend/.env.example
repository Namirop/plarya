# URL publique du site, sert de base pour metadataBase, canonical
# URLs, sitemap, robots, et URLs JSON-LD. Doit refléter le domaine
# réellement servi (sans trailing slash).
NEXT_PUBLIC_SITE_URL=https://plarya.com

# URL de l'API backend appelée depuis le browser. Mêmes règles que
# au-dessus (pas de trailing slash). En dev : http://localhost:4000.
NEXT_PUBLIC_API_URL=https://api.plarya.com
