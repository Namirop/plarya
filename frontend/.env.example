# ─────────────────────────────────────────────────────────────
# Plarya — Frontend env vars
#
# Copy to .env.local pour le développement local. Toutes les vars
# `NEXT_PUBLIC_*` sont baked au build et exposées côté browser →
# ne mettre AUCUN secret ici.
# ─────────────────────────────────────────────────────────────

# URL canonique du site (utilisée pour metadataBase SEO, sitemap,
# canonical URLs, JSON-LD ProfilePage). Doit refléter le domaine
# réellement servi (sans trailing slash).
NEXT_PUBLIC_SITE_URL=https://plarya.com

# URL de l'API backend, utilisée par :
#  - lib/api.ts (apiFetch côté client browser)
#  - lib/server-fetch.ts (server components, fetch SSR)
#  - generateMetadata, sitemap, opengraph-image
# En dev : http://localhost:4000. En prod : https://api.plarya.com.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────
# Launch protection (HTTP Basic Auth) — vars SERVEUR (pas de
# préfixe NEXT_PUBLIC : ce sont des secrets, lus dans proxy.ts).
#
# Verrou temporaire pour masquer le site au public jusqu'au launch.
# Géré dans frontend/proxy.ts (gate Basic Auth). Couvre uniquement
# ce frontend (le backend api.plarya.com n'est pas concerné).
#
# LAUNCH_PROTECT_ENABLED : "true" => le site exige une auth Basic
#   (popup navigateur) sur toutes les pages. Toute autre valeur (ou
#   absent) => site public, aucun effet (no-op).
# LAUNCH_PROTECT_USERNAME / _PASSWORD : identifiants uniques. Si
#   ENABLED=true mais ces 2 vars manquent => accès bloqué (fail-closed).
#
# Toggle sans toucher au code : changer la var sur Vercel + redeploy.
# Au launch => LAUNCH_PROTECT_ENABLED=false (ou supprimer la var).
# ─────────────────────────────────────────────────────────────
LAUNCH_PROTECT_ENABLED=
LAUNCH_PROTECT_USERNAME=
LAUNCH_PROTECT_PASSWORD=
