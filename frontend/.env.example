# ─────────────────────────────────────────────────────────────
# Plarya — Frontend env vars
#
# Copy to .env.local pour le développement local. Toutes les vars
# `NEXT_PUBLIC_*` sont baked au build et exposées côté browser →
# ne mettre AUCUN secret ici.
# ─────────────────────────────────────────────────────────────

# URL canonique du site (utilisée pour metadataBase SEO, sitemap,
# canonical URLs, JSON-LD ProfilePage). Doit refléter le domaine
# réellement servi (sans trailing slash).
NEXT_PUBLIC_SITE_URL=https://plarya.com

# URL de l'API backend, utilisée par :
#  - lib/api.ts (apiFetch côté client browser)
#  - lib/server-fetch.ts (server components, fetch SSR)
#  - generateMetadata, sitemap, opengraph-image
# En dev : http://localhost:4000. En prod : https://api.plarya.com.
NEXT_PUBLIC_API_URL=http://localhost:4000
