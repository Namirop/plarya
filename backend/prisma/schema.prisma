generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum UserRole {
  USER
  TIPSTER
  ADMIN
}

enum PronoResult {
  PENDING
  WON
  LOST
}

enum PronoTeasing {
  PICK_SOLIDE
  VALUE
  SAFE
  OPPORTUNITE
  PICK_DU_JOUR
  A_NE_PAS_RATER
}

enum SubscriptionType {
  DAY_PASS
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TipsterSubStatus {
  FREE
  ACTIVE
  EXPIRED
}

enum Sport {
  FOOTBALL
  TENNIS
  BASKETBALL
  RUGBY
  HOCKEY
  MMA
  BOXE
  ESPORT
  AUTRE
}

// ──────────────────────────────────────
// Models
// ──────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tipster       Tipster?
  subscriptions Subscription[]

  @@map("users")
}

model Tipster {
  id              String          @id @default(cuid())
  userId          String          @unique
  pseudo          String          @unique
  bio             String?
  photoUrl        String?
  sports          Sport[]
  dayPassPrice    Int             @default(300)  // centimes (3€)
  monthlyPrice    Int             @default(1900) // centimes (19€)
  subStatus       TipsterSubStatus @default(FREE)
  subExpiresAt    DateTime?
  warningMessage  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pronos          Prono[]
  subscriptions   Subscription[]

  @@map("tipsters")
}

model Prono {
  id          String       @id @default(cuid())
  tipsterId   String
  matchName   String       // ex: "PSG - Marseille"
  league      String?      // ex: "Ligue 1"
  pick        String       // ex: "PSG gagne"
  odds        Float        // cote du tipster
  teasing     PronoTeasing
  result      PronoResult  @default(PENDING)
  argument    String?      // argumentaire (visible après achat)
  matchDate   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tipster     Tipster      @relation(fields: [tipsterId], references: [id], onDelete: Cascade)

  @@index([tipsterId, createdAt(sort: Desc)])
  @@map("pronos")
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  tipsterId         String
  type              SubscriptionType
  status            SubscriptionStatus @default(ACTIVE)
  stripeSessionId   String?
  stripeSubId       String?
  expiresAt         DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipster           Tipster            @relation(fields: [tipsterId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tipsterId])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Bookmaker {
  id             String          @id @default(cuid())
  name           String          @unique // Winamax, Betclic, PMU
  logoUrl        String?
  createdAt      DateTime        @default(now())

  affiliateLinks AffiliateLink[]

  @@map("bookmakers")
}

model AffiliateLink {
  id           String    @id @default(cuid())
  bookmakerId  String
  url          String
  label        String?   // ex: "Parier +100€"
  createdAt    DateTime  @default(now())

  bookmaker    Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)

  @@map("affiliate_links")
}
