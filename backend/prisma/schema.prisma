generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum UserRole {
  USER
  TIPSTER
  ADMIN
}

enum PronoResult {
  PENDING
  WON
  LOST
}

enum PronoTeasing {
  PICK_SOLIDE
  VALUE
  SAFE
  OPPORTUNITE
  PICK_DU_JOUR
  A_NE_PAS_RATER
}

enum SubscriptionType {
  DAY_PASS
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TipsterSubStatus {
  FREE
  ACTIVE
  EXPIRED
}

enum Sport {
  FOOTBALL
  TENNIS
  BASKETBALL
  RUGBY
  HOCKEY
  MMA
  BOXE
  ESPORT
  AUTRE
}

// ──────────────────────────────────────
// Models
// ──────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tipster       Tipster?
  subscriptions Subscription[]
  sessions      Session[]

  @@map("users")
}

model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@map("magic_links")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Tipster {
  id              String          @id @default(cuid())
  userId          String          @unique
  pseudo          String          @unique
  bio             String?
  photoUrl        String?
  sports          Sport[]
  dayPassPrice    Int             @default(350)  // centimes (3.50€)
  monthlyPrice    Int             @default(1900) // centimes (19€)
  subStatus       TipsterSubStatus @default(FREE)
  subExpiresAt    DateTime?
  stripeSubId     String?          // Stripe subscription for tipster quarterly plan
  warningMessage  String?
  dailyNote       String?
  dailyNoteDate   DateTime?
  displayOrder    Int             @default(0)
  viewsToday      Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pronos          Prono[]
  subscriptions   Subscription[]

  @@map("tipsters")
}

model Prono {
  id          String       @id @default(cuid())
  tipsterId   String
  matchName   String       // ex: "PSG - Marseille"
  league      String?      // ex: "Ligue 1"
  pick        String       // ex: "PSG gagne"
  odds        Float        // cote du tipster
  teasing     PronoTeasing
  result      PronoResult  @default(PENDING)
  argument    String?      // argumentaire (visible après achat)
  startTime   DateTime     // heure de début du match
  isFeatured  Boolean      @default(false)
  matchDate   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tipster       Tipster              @relation(fields: [tipsterId], references: [id], onDelete: Cascade)
  bookmakerOdds PronoBookmakerOdds[]

  @@index([tipsterId, createdAt(sort: Desc)])
  @@map("pronos")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String
  tipsterId             String
  type                  SubscriptionType
  status                SubscriptionStatus @default(ACTIVE)
  stripeSessionId       String?
  stripeSubId           String?
  checkoutSessionUsed   Boolean            @default(false)
  expiresAt             DateTime
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipster           Tipster            @relation(fields: [tipsterId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tipsterId])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Bookmaker {
  id             String          @id @default(cuid())
  name           String          @unique // Winamax, Betclic, PMU
  logoUrl        String?
  createdAt      DateTime        @default(now())

  affiliateLinks AffiliateLink[]
  pronoOdds      PronoBookmakerOdds[]

  @@map("bookmakers")
}

model AffiliateLink {
  id           String    @id @default(cuid())
  bookmakerId  String
  url          String
  label        String?   // ex: "Parier +100€"
  createdAt    DateTime  @default(now())

  bookmaker    Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)

  @@map("affiliate_links")
}

model PronoBookmakerOdds {
  id           String    @id @default(cuid())
  pronoId      String
  bookmakerId  String
  odds         Float

  prono        Prono     @relation(fields: [pronoId], references: [id], onDelete: Cascade)
  bookmaker    Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)

  @@unique([pronoId, bookmakerId])
  @@index([pronoId])
  @@map("prono_bookmaker_odds")
}
