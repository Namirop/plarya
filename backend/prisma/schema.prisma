generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum UserRole {
  USER
  EXPERT
  ADMIN
}

enum PronoResult {
  PENDING
  WON
  LOST
}

enum PronoTeasing {
  PICK_SOLIDE
  VALUE
  SAFE
  OPPORTUNITE
  PICK_DU_JOUR
  A_NE_PAS_RATER
}

enum SubscriptionType {
  DAY_PASS
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ExpertSubStatus {
  FREE
  ACTIVE
  EXPIRED
}

enum Sport {
  FOOTBALL
  TENNIS
  BASKETBALL
  RUGBY
  HOCKEY
  MMA
  BOXE
  ESPORT
  AUTRE
}

// ──────────────────────────────────────
// Models
// ──────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  // Stripe Customer ID (cus_xxx). Persisté au premier paiement pour
  // que les achats suivants réutilisent le même Customer côté Stripe
  // (évite les doublons, facilite le support + dashboard).
  stripeCustomerId  String?  @unique
  role              UserRole @default(USER)
  // Soft delete RGPD : null = compte actif. Quand un user demande
  // la suppression de son compte (cf. DELETE /auth/me), on pose
  // deletedAt + anonymise email = `deleted-${id}@plarya.local`. Le
  // row reste en DB pour conserver les FK des Subscriptions (oblig.
  // comptable). Tous les endpoints publics filtrent deletedAt IS NULL.
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  expert        Expert?
  subscriptions Subscription[]
  sessions      Session[]

  @@index([deletedAt])
  @@map("users")
}

// Cooldown anti re-login après suppression de compte.
//
// Quand un user supprime son compte (cf. DELETE /auth/me, branche
// immediate, ET le cron auto_delete_pending_experts), on anonymise
// `User.email = deleted-{id}@plarya.local` → impossible de retrouver
// l'email original depuis User. Sans contre-mesure, l'user (ou pire,
// quelqu'un d'autre avec accès à sa boîte mail) peut tout de suite
// re-demander un magic-link sur l'email original → /auth/verify
// trouve aucun User → en crée un nouveau → "re-login" magique.
//
// Cette table garde un cooldown explicite : on insère `email` (en
// clair, l'original) au moment du soft delete, avec un `expiresAt`
// (now + 7 jours par défaut). Pendant cette fenêtre, le
// request-magic-link sur cet email est silencieusement refusé (200
// sans envoi d'email, comme un email inconnu — anti-énumération).
//
// Purge : cron quotidien à 03:00 supprime les rows expiresAt < now
// (cf. lib/cron.ts) → on ne garde pas l'email indéfiniment, conforme
// à l'esprit du droit à l'oubli RGPD.
model DeletedEmailCooldown {
  id        String   @id @default(cuid())
  email     String
  deletedAt DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("deleted_email_cooldowns")
}

model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@map("magic_links")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Expert {
  id              String          @id @default(cuid())
  userId          String          @unique
  pseudo          String          @unique
  bio             String?
  photoUrl        String?
  sports          Sport[]
  dayPassPrice    Int             @default(350)  // centimes (3.50€)
  monthlyPrice    Int             @default(2900) // centimes (29€)
  subStatus       ExpertSubStatus @default(FREE)
  subExpiresAt    DateTime?
  stripeSubId     String?         // Stripe subscription for expert quarterly plan
  warningMessage  String?
  dailyNote       String?
  dailyNoteDate   DateTime?
  displayOrder    Int             @default(0)
  viewsToday      Int             @default(0)
  // Soft delete RGPD (cf. User.deletedAt). Profile expert masqué
  // publiquement quand non-null mais conservé pour l'historique
  // Subscriptions / audit Stripe.
  deletedAt       DateTime?
  // Suppression programmée. Quand un expert demande à supprimer son
  // compte alors qu'il a des Subscriptions ACTIVE en cours, on ne
  // peut pas supprimer immédiatement (l'acheteur a payé pour X jours
  // d'accès). On flag pendingDeletionAt = now et :
  //   - le profile est retiré des listings publics
  //   - les nouveaux paiements sont bloqués (création de sub refusée)
  //   - les subs existantes continuent à fonctionner jusqu'à expiresAt
  //   - un cron quotidien check les experts pending : quand la dernière
  //     sub active a expiré → soft delete automatique (deletedAt set).
  // L'expert peut annuler tant que deletedAt n'est pas posé.
  pendingDeletionAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pronos          Prono[]
  subscriptions   Subscription[]

  @@index([deletedAt])
  @@index([pendingDeletionAt])
  @@index([stripeSubId])
  @@map("experts")
}

model Prono {
  id          String       @id @default(cuid())
  expertId    String
  matchName   String       // ex: "PSG - Marseille"
  league      String?      // ex: "Ligue 1"
  pick        String       // ex: "PSG gagne"
  odds        Float        // cote de l'expert
  teasing     PronoTeasing
  result      PronoResult  @default(PENDING)
  argument    String?      // argumentaire (visible après achat)
  startTime   DateTime     // heure de début du match
  isFeatured  Boolean      @default(false)
  matchDate   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  expert        Expert               @relation(fields: [expertId], references: [id], onDelete: Cascade)
  bookmakerOdds PronoBookmakerOdds[]

  @@index([expertId, createdAt(sort: Desc)])
  @@map("pronos")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String
  expertId              String
  type                  SubscriptionType
  status                SubscriptionStatus @default(ACTIVE)
  stripeSessionId       String?            @unique
  stripeSubId           String?
  checkoutSessionUsed   Boolean            @default(false)
  expiresAt             DateTime
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  expert            Expert             @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expertId])
  @@index([expiresAt])
  @@index([stripeSubId])
  @@map("subscriptions")
}

model Bookmaker {
  id             String          @id @default(cuid())
  name           String          @unique // Winamax, Betclic, PMU
  logoUrl        String?
  createdAt      DateTime        @default(now())

  affiliateLinks AffiliateLink[]
  pronoOdds      PronoBookmakerOdds[]

  @@map("bookmakers")
}

model AffiliateLink {
  id           String    @id @default(cuid())
  bookmakerId  String
  url          String
  label        String?   // ex: "Parier +100€"
  createdAt    DateTime  @default(now())

  bookmaker    Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)

  @@map("affiliate_links")
}

// Table d'idempotence event-level pour les webhooks Stripe.
// Chaque event Stripe est identifié par son `id` (evt_xxx) ; on log
// l'event UNE FOIS qu'on l'a traité avec succès (dans la même
// transaction que la logique business). Si Stripe re-livre le même
// event (timeout réseau, retry après 5xx), on skip via le `findUnique`
// au début du handler — cf. webhooks.ts.
//
// `payload` stocké en Json pour audit/debug en cas de litige Stripe
// (durée prévue : >= 90 jours pour matcher la fenêtre de dispute).
// On reverra cette politique en V2 si la table grossit trop.
model StripeWebhookEvent {
  id          String   @id  // evt_xxx fourni par Stripe
  eventType   String
  payload     Json?
  processedAt DateTime @default(now())

  @@index([processedAt])
  @@map("stripe_webhook_events")
}

model PronoBookmakerOdds {
  id           String    @id @default(cuid())
  pronoId      String
  bookmakerId  String
  odds         Float

  prono        Prono     @relation(fields: [pronoId], references: [id], onDelete: Cascade)
  bookmaker    Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)

  @@unique([pronoId, bookmakerId])
  @@index([pronoId])
  @@map("prono_bookmaker_odds")
}
