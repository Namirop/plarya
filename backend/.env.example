# ─────────────────────────────────────────────────────────────
# Plarya — Backend env vars
#
# Copy to .env pour le développement local. NE PAS COMMITER de
# vraies valeurs — toutes les clés Stripe / Resend doivent rester
# dans .env (gitignored).
# ─────────────────────────────────────────────────────────────

# ── Database ──
# Postgres connection string (cf. Prisma docs). Pour Docker local :
# postgresql://postgres:postgres@localhost:5432/plarya
#
# En prod (Neon) : DATABASE_URL = endpoint POOLÉ (-pooler), utilisé par
# le runtime serverless. Garder "?sslmode=require" si l'hôte l'exige.
DATABASE_URL=postgresql://user:password@localhost:5432/plarya

# URL DIRECTE (non poolée) pour les migrations `prisma migrate deploy`.
# Sur Neon : même connexion SANS le suffixe "-pooler". En local : laisser
# vide → fallback automatique sur DATABASE_URL (cf. prisma.config.ts).
DIRECT_URL=

# ── Server ──
PORT=4000
NODE_ENV=development

# ── CORS ──
# Liste comma-separated des origines autorisées. En dev = frontend
# local, en prod = domaine déployé Plarya.
CORS_ORIGINS=http://localhost:3000

# ── URLs (utilisées pour les magic-links + Stripe redirects) ──
# En prod : FRONTEND_URL = domaine Vercel (custom ou *.vercel.app),
# BACKEND_URL = domaine public Railway de l'API.
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ── Cookies / sessions ──
# SameSite des cookies session + CSRF.
#  - "lax" (recommandé) si front et back partagent le même eTLD+1
#    (ex plarya.com + api.plarya.com) → plus sûr.
#  - "none" si front et back sont sur des domaines DIFFÉRENTS (ex
#    *.vercel.app + *.up.railway.app) : sinon le cookie cross-site est
#    bloqué et l'utilisateur ne reste pas connecté. "none" force Secure.
COOKIE_SAMESITE=lax

# Domaine des cookies. Vide en local (host-only). En prod cross-subdomain
# (front plarya.com + back api.plarya.com), poser ".plarya.com" pour
# PARTAGER le cookie entre l'apex et le sous-domaine — indispensable au
# rendu serveur des pages connectées (/compte, /dashboard) : le serveur
# Next (plarya.com) ne reçoit le cookie de session que s'il est scopé
# .plarya.com. Doit être un parent du domaine du backend.
COOKIE_DOMAIN=

# ── Stripe ──
# Clé secrète serveur — JAMAIS exposée côté browser. Récupérer
# depuis https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx

# Secret webhook signing. En local, `stripe listen` génère un secret
# whsec_* qu'il faut copier ici. En prod : configuré dans le
# Dashboard Stripe → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Resend (envoi d'emails) ──
# Clé API : https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Adresse d'expédition. En dev : onboarding@resend.dev (sandbox, seul
# "from" autorisé sans domaine vérifié). En prod : domaine vérifié dans
# Resend, format "Nom <email>", ex "Plarya <noreply@plarya.com>".
EMAIL_FROM="Plarya <onboarding@resend.dev>"

# ── Logging ──
# Niveau pino. Default : "debug" en dev, "info" en prod.
LOG_LEVEL=info
